# ─────────────────────────────────────────────────────────────
# EV 차고 — 환경 변수 예시
# 이 파일을 .env 로 복사한 뒤 값을 채우세요.  cp .env.example .env
# EXPO_PUBLIC_ 접두사가 붙은 값은 앱 번들에 포함됩니다(클라이언트 노출 OK한 값만).
# .env 는 절대 깃에 커밋하지 마세요.
# ─────────────────────────────────────────────────────────────

# Supabase (대시보드 > Project Settings > API)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# 공공데이터포털 - 한국환경공단 전기차 충전소 (Phase 4)
# https://www.data.go.kr/data/15076352/openapi.do
EXPO_PUBLIC_DATA_GO_KR_KEY=YOUR-DATA-GO-KR-KEY

# 카카오맵 JavaScript 키 (Phase 4)
EXPO_PUBLIC_KAKAO_MAP_KEY=YOUR-KAKAO-JS-KEY
